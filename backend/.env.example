PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081

# AWS RDS PostgreSQL (choose DATABASE_URL or individual fields)
DATABASE_URL=postgresql://username:password@your-db-id.xxxxx.ap-southeast-2.rds.amazonaws.com:5432/two_cents
DB_HOST=your-db-id.xxxxx.ap-southeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=two_cents
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=true

# Session auth
SESSION_COOKIE_NAME=two_cents_session
SESSION_TTL_DAYS=7
